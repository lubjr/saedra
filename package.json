{
  "name": "saedra",
  "private": true,
  "scripts": {
    "build": "turbo run build",
    "build:fresh": "pnpm run clean && pnpm run build",
    "dev": "dotenv -e .env -- turbo run dev --concurrency=20",
    "dev:fresh": "pnpm run clean && pnpm run dev",
    "dev:infra": "sudo docker-compose -f docker/docker-compose.yml up -d",
    "stop:infra": "sudo docker-compose -f docker/docker-compose.yml down",
    "dev:apps": "concurrently --names \"WEB,API\" --prefix-colors \"cyan,magenta\" \"pnpm run dev --filter ./apps/web\" \"pnpm run dev --filter ./apps/api\"",
    "dev:all": "pnpm run dev:infra && sleep 5 && pnpm run dev:apps",
    "clean": "rm -rf .next .turbo node_modules/.cache apps/*/.next packages/*/dist packages/*/.next && echo '✨ Cache cleaned!'",
    "clean:all": "pnpm run clean && rm -rf node_modules apps/*/node_modules packages/*/node_modules && echo '✨ Full clean complete! Run: pnpm install'",
    "lint": "turbo run lint",
    "format": "prettier --write \"**/*.{ts,tsx,md}\"",
    "check-types": "turbo run check-types",
    "test": "turbo run test"
  },
  "devDependencies": {
    "concurrently": "^9.2.4",
    "dotenv-cli": "^7.4.4",
    "prettier": "^3.9.5",
    "turbo": "^2.10.5",
    "typescript": "5.8.3"
  },
  "packageManager": "pnpm@10.33.0",
  "engines": {
    "node": ">=18"
  },
  "pnpm": {
    "overrides": {
      "@types/express-serve-static-core": "5.0.7",
      "@types/qs": "6.14.0",
      "@ttoss/eslint-config": "1.26.4",
      "@supabase/supabase-js": "2.57.4",
      "@aws-sdk/client-s3": "3.901.0",
      "@aws-sdk/client-ec2": "3.901.0",
      "@aws-sdk/client-rds": "3.901.0",
      "@aws-sdk/client-bedrock": "3.947.0",
      "@aws-sdk/client-bedrock-runtime": "3.947.0",
      "aws-sdk": "2.1692.0"
    }
  }
}
